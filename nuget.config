<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!--
      Local feed for packages built from this solution.
      Run `dotnet pack` to populate this folder, then `dotnet add package` from PlatformTestApp.
    -->
    <add key="YouVersionLocal" value="./packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
