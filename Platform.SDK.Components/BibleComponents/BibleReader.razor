@using Platform.SDK.Components.BibleComponents.Verses

@* ── Picker toolbar ──────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    <div class="col-12 col-md-3">
        <VersionPicker />
    </div>
    <div class="col-12 col-md-3">
        <BookPicker />
    </div>
    <div class="col-12 col-md-2">
        <ChapterPicker />
    </div>
    <div class="col-12 col-md-3">
        <VersePicker />
    </div>
    <div class="col-12 col-md-1 d-flex align-items-end">
        <button class="btn btn-primary w-100"
                @onclick="ReadPassageAsync"
                disabled="@(!CanRead)">
            Read
        </button>
    </div>
</div>

@* ── Verse area ────────────────────────────────────────────────── *@
@if (_passage is not null)
{
    <VerseComponent Passage="@_passage" Copyright="@_copyright" />
}
else if (_loading)
{
    <div class="mt-3 text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading passage…</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger mt-3">@_error</div>
}
else if (CanRead)
{
    <p class="text-muted mt-3 small">Press <strong>Read</strong> to load the passage.</p>
}
