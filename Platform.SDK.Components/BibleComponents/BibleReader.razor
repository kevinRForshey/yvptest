@using Platform.SDK.Components.BibleComponents.Verses

@* ── Picker toolbar ──────────────────────────────────────────────── *@
<div class="bible-picker-shell">
    <div class="bible-picker-glow" aria-hidden="true"></div>

    <div class="bible-picker-header">
        <div>
            <span class="bible-picker-eyebrow">Choose your passage</span>
            <h3 class="bible-picker-title">Bible Reader</h3>
        </div>

        <div class="bible-picker-mark" aria-hidden="true">
            ✦
        </div>
    </div>

    <div class="row g-3 bible-picker-grid">
        <div class="col-12 col-md-3">
            <section class="picker-card">
                <span class="picker-label">Version</span>
                <VersionPicker />
            </section>
        </div>

        <div class="col-12 col-md-3">
            <section class="picker-card">
                <span class="picker-label">Book</span>
                <BookPicker />
            </section>
        </div>

        <div class="col-12 col-md-2">
            <section class="picker-card">
                <span class="picker-label">Chapter</span>
                <ChapterPicker />
            </section>
        </div>

        <div class="col-12 col-md-3">
            <section class="picker-card">
                <span class="picker-label">Verse</span>
                <VersePicker
                    Book="@State.SelectedBook!.Usfm"
                    Chapter="@State.SelectedChapter!.Value"
                    Verse="@(State.SelectedVerseStart ?? 0)"
                    VerseEnd="@(State.SelectedVerseEnd ?? 0)"
                    VersionId="@State.SelectedVersion!.Id" />
            </section>
        </div>

        <div class="col-12 col-md-1 d-flex align-items-end">
            <button class="read-passage-button w-100"
                    @onclick="ReadPassageAsync"
                    disabled="@(!CanRead)">
                Read
            </button>
        </div>
    </div>
</div>

@* ── Verse area ────────────────────────────────────────────────── *@
@if (_passage is not null)
{
    <VerseComponent Passage="@_passage" Copyright="@_copyright" />
}
else if (_loading)
{
    <div class="mt-3 text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading passage…</span>
        </div>
    </div>
}
else if (_error is not null)
{
    <div class="alert alert-danger mt-3">@_error</div>
}
else if (CanRead)
{
    <p class="text-muted mt-3 small">Press <strong>Read</strong> to load the passage.</p>
}