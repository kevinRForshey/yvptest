<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- ============================ NuGet package metadata ============================ -->
  <PropertyGroup>
    <PackageId>YouVersion.UsfmReferences</PackageId>
    <Version>3.1.1</Version>

    <Title>YouVersion USFM References</Title>
    <Authors>YouVersion</Authors>
    <Company>YouVersion</Company>
    <Product>YouVersion.UsfmReferences</Product>
    <Description>Parsing, validation, and conversion utilities for USFM (Unified Standard Format Markers) scripture references. A C# port of the youversion/usfm-references Python library.</Description>
    <PackageTags>usfm;bible;scripture;reference;youversion;parsing;validation;canon</PackageTags>
    <Copyright>Copyright © 2026 YouVersion</Copyright>

    <!-- License: MIT, consistent with the upstream project. -->
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <!-- README shown on the nuget.org package page. -->
    <PackageReadmeFile>README.md</PackageReadmeFile>
    
    <PackageProjectUrl>https://github.com/kevinRForshey/SimpleYouVersionPlatformDotNetSDK</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kevinRForshey/SimpleYouVersionPlatformDotNetSDK</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <PackageReleaseNotes>Initial .NET release. Feature-equivalent port of usfm-references 3.1.1.</PackageReleaseNotes>

    <!-- Optional package icon: drop an icon.png next to this file and uncomment.
    <PackageIcon>icon.png</PackageIcon>
    -->
  </PropertyGroup>

  <!-- ===================== Build reproducibility & source debugging ===================== -->
  <PropertyGroup>
    <!-- Ship a .snupkg symbol package so consumers can step into the source. -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- SourceLink ships in the .NET 8+ SDK; no extra PackageReference needed. -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>

    <!-- Deterministic output on CI only, so local builds stay clean. -->
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- Pack the solution-level README into the package root. -->
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
